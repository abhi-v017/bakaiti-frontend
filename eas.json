{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bakaiti-backend.onrender.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://bakaiti-backend.onrender.com"
      }
    },
    "preview": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bakaiti-backend-production.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://bakaiti-backend-production.up.railway.app"
      },
      "distribution": "internal"
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://bakaiti-backend-production.up.railway.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://bakaiti-backend-production.up.railway.app"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
